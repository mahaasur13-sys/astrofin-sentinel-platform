# AstroFin Sentinel V5 — Database Environment Variables
# Copy to .env and fill in your values

# ============================================================
# POSTGRESQL (Primary — TimescaleDB + pgvector)
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=astrofin
POSTGRES_USER=astrofin
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ============================================================
# REDIS (Cache + Session)
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================
# BACKEND SELECTION
# Set to "postgresql" for full features, "sqlite" for dev
# ============================================================
DB_BACKEND=postgresql

# ============================================================
# OPTIONAL: TimescaleDB retention (days)
# ============================================================
# TIMESERIES_RETENTION=90
# AUDIT_RETENTION=730

# ============================================================
# SQL ECHO (set to "1" for SQL debugging)
# ============================================================
# SQL_ECHO=
