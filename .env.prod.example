# AstroFin Sentinel Platform — Production Environment Variables
# Copy to .env.prod and fill in REAL values (NEVER commit .env.prod)

POSTGRES_USER=astrofin
POSTGRES_DB=astrofin
POSTGRES_HOST=postgres.prod.internal
POSTGRES_PORT=5432
POSTGRES_PASSWORD=CHANGEME_use_openssl_rand_base64_32
REDIS_URL=redis://redis.prod.internal:6379/0
API_KEY=CHANGEME_use_openssl_rand_hex_32
JWT_SECRET=CHANGEME_use_openssl_rand_hex_64
OPENAI_API_KEY=sk-CHANGEME_replace_with_real_key
METRICS_API_KEY=CHANGEME_use_openssl_rand_hex_32
S3_BUCKET=astrofin-prod-backups
S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=CHANGEME
AWS_SECRET_ACCESS_KEY=CHANGEME
SENTRY_DSN=https://CHANGEME@sentry.io/123
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.prod.internal:4317
ALLOWED_ORIGINS=https://app.example.com
REQUIRE_AUTH=true
LOG_LEVEL=INFO
TZ=UTC
ENVIRONMENT=production
