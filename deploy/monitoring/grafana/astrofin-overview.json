{
  "title": "AstroFin Sentinel \u2014 Overview",
  "uid": "astrofin-overview",
  "panels": [
    {
      "title": "Agent Confidence (avg)",
      "type": "gauge",
      "targets": [
        {
          "expr": "avg(agent_confidence)"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      }
    },
    {
      "title": "RAG Retrieval Latency (p99)",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rag_retrieval_duration_seconds_bucket)"
        }
      ],
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      }
    },
    {
      "title": "DB Query Duration (p50/p95/p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, db_query_duration_seconds_bucket)",
          "legendFormat": "p50 {{backend}}"
        },
        {
          "expr": "histogram_quantile(0.95, db_query_duration_seconds_bucket)",
          "legendFormat": "p95 {{backend}}"
        },
        {
          "expr": "histogram_quantile(0.99, db_query_duration_seconds_bucket)",
          "legendFormat": "p99 {{backend}}"
        }
      ],
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      }
    },
    {
      "title": "RAG Chunks Returned",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rag_chunks_returned"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 8,
        "h": 4
      }
    },
    {
      "title": "DB Pool Size",
      "type": "timeseries",
      "targets": [
        {
          "expr": "db_pool_size"
        }
      ],
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 8,
        "h": 4
      }
    },
    {
      "title": "Active WS Connections",
      "type": "stat",
      "targets": [
        {
          "expr": "ws_connections_active"
        }
      ],
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 4
      }
    }
  ]
}