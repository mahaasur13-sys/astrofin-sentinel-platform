{
  "dashboard": {
    "title": "Home Cluster — Full Overview",
    "uid": "home-cluster-overview",
    "panels": [
      {
        "title": "Cluster Health",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {"expr": "up{job='node'}", "legendFormat": "{{instance}}"}
        ]
      },
      {
        "title": "GPU Utilization (RTX 3060)",
        "type": "gauge",
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "targets": [
          {"expr": "DCGM_FI_DEV_GPU_UTIL{node='rtx-node'}", "legendFormat": "GPU%"}
        ]
      },
      {
        "title": "Node CPU Load",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 4},
        "targets": [
          {"expr": "100 - (idle{job='node'})", "legendFormat": "{{instance}}"}
        ]
      },
      {
        "title": "Slurm Jobs",
        "type": "table",
        "gridPos": {"x": 0, "y": 4, "w": 8, "h": 4},
        "targets": [
          {"expr": "slurm_jobs{state='RUNNING'}", "legendFormat": "{{job_name}}"}
        ]
      },
      {
        "title": "Ceph OSD Usage",
        "type": "gauge",
        "gridPos": {"x": 8, "y": 4, "w": 8, "h": 4},
        "targets": [
          {"expr": "ceph_osd_op_rate", "legendFormat": "{{osd}}"}
        ]
      },
      {
        "title": "Ray Cluster Actors",
        "type": "stat",
        "gridPos": {"x": 16, "y": 4, "w": 8, "h": 4},
        "targets": [
          {"expr": "ray_actors", "legendFormat": "actors"}
        ]
      },
      {
        "title": "WireGuard Peers",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 4},
        "targets": [
          {"expr": "wireguard_peer_transfer_bytes", "legendFormat": "{{peer}}"}
        ]
      },
      {
        "title": "Memory Free",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 4},
        "targets": [
          {"expr": "mem_avail", "legendFormat": "{{instance}}"}
        ]
      }
    ],
    "refresh": "10s",
    "schemaVersion": 30
  }
}
