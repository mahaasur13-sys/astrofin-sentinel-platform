"""CCXT adapter implementing IMarketDataSource."""
import ccxt
from src.domain.market_data.interfaces import DomainOHLCV, IMarketDataSource


class CCXTAdapter(IMarketDataSource):
    """Fetches real market data via CCXT, normalizing symbols."""

    SYMBOL_MAP = {
        "BTCUSDT": "BTC/USDT",
        "ETHUSDT": "ETH/USDT",
        "SOLUSDT": "SOL/USDT",
        "BNBUSDT": "BNB/USDT",
    }

    REVERSE_MAP = {v: k for k, v in SYMBOL_MAP.items()}

    def __init__(self, exchange_name: str = "binance", sandbox: bool = True):
        self.exchange = getattr(ccxt, exchange_name)({
            "enableRateLimit": True,
            "options": {"defaultType": "spot"},
        })
        if sandbox:
            self.exchange.set_sandbox_mode(True)

    def normalize_symbol(self, raw_symbol: str) -> str:
        """Convert any format to canonical (e.g., BTC/USDT -> BTCUSDT)."""
        return self.REVERSE_MAP.get(raw_symbol, raw_symbol.replace("/", ""))

    def fetch(self, symbol: str, timeframe: str, limit: int = 500) -> DomainOHLCV:
        """Fetch OHLCV and return canonical DomainOHLCV."""
        ccxt_symbol = self.SYMBOL_MAP.get(symbol, symbol)
        ohlcv = self.exchange.fetch_ohlcv(ccxt_symbol, timeframe, limit=limit)

        return DomainOHLCV(
            symbol=self.normalize_symbol(ccxt_symbol),
            timeframe=timeframe,
            open=[b[1] for b in ohlcv],
            high=[b[2] for b in ohlcv],
            low=[b[3] for b in ohlcv],
            close=[b[4] for b in ohlcv],
            volume=[b[5] for b in ohlcv],
            timestamp=[int(b[0]) for b in ohlcv],
        )
