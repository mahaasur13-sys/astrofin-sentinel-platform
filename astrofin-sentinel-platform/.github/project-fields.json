{
  "name": "AstroFin Sentinel — v1.0.0 Production",
  "description": "Production-readiness backlog. MoSCoW: 31 MUST / 35 SHOULD / 17 COULD / 4 WON'T. Target GA: 2026-08-05. See RELEASE_PLAN_v1.0.0.md",
  "owner": "mahaasur13-sys",
  "fields": [
    {
      "name": "Status",
      "type": "single_select",
      "options": ["Backlog", "Sprint Ready", "In Progress", "Review", "Blocked", "Done"],
      "default": "Backlog"
    },
    {
      "name": "MoSCoW",
      "type": "single_select",
      "options": ["must", "should", "could", "wont"],
      "required": true
    },
    {
      "name": "Phase",
      "type": "single_select",
      "options": ["phase-0", "phase-1", "phase-2", "phase-3", "phase-4", "phase-5"]
    },
    {
      "name": "Estimate (h)",
      "type": "number",
      "required": false
    },
    {
      "name": "Actual (h)",
      "type": "number",
      "required": false
    },
    {
      "name": "Sprint",
      "type": "single_select",
      "options": ["Sprint 1", "Sprint 2", "Sprint 3", "Sprint 4", "Backlog"]
    },
    {
      "name": "Owner",
      "type": "single_select",
      "options": ["@asurdev", "@mahaasur13-sys", "unassigned"]
    },
    {
      "name": "Area",
      "type": "single_select",
      "options": ["backend", "devops", "security", "docs", "qa"]
    },
    {
      "name": "Risk",
      "type": "single_select",
      "options": ["R1-submodule", "R2-bus-factor", "R3-snapshot", "R4-secret-leak", "R5-tests", "R10-jwt-migration", "R11-pgvector-size", "R17-pentest", "R20-perf", "none"]
    },
    {
      "name": "Target Date",
      "type": "date"
    }
  ],
  "views": [
    {
      "name": "📊 Board (default)",
      "layout": "board",
      "group_by": "Status",
      "sort_by": "Priority"
    },
    {
      "name": "📅 By Milestone",
      "layout": "table",
      "group_by": "Milestone",
      "filter": "is:open"
    },
    {
      "name": "🏷️ By MoSCoW",
      "layout": "table",
      "group_by": "MoSCoW",
      "filter": "is:open"
    },
    {
      "name": "👤 My Workload",
      "layout": "board",
      "group_by": "Status",
      "filter": "assignee:@me"
    },
    {
      "name": "📈 Sprint Burndown",
      "layout": "roadmap",
      "group_by": "Sprint"
    }
  ],
  "automations": [
    {
      "name": "New issue → Backlog",
      "trigger": "issues.opened",
      "action": "set_field Status=Backlog"
    },
    {
      "name": "Add to project on issue open",
      "trigger": "issues.opened",
      "action": "add_to_project"
    },
    {
      "name": "Phase label → MoSCoW auto-fill",
      "trigger": "issues.labeled",
      "condition": "label matches /^phase-/",
      "action": "set_field Phase=<label>"
    },
    {
      "name": "milestone set → Sprint Ready",
      "trigger": "issues.edited",
      "condition": "milestone is set",
      "action": "set_field Status=Sprint Ready"
    },
    {
      "name": "Assignee set → In Progress",
      "trigger": "issues.assigned",
      "action": "set_field Status=In Progress"
    },
    {
      "name": "PR opened → Review",
      "trigger": "pull_request.opened",
      "condition": "linked issue exists",
      "action": "set_field Status=Review on linked issue"
    },
    {
      "name": "PR merged → Done",
      "trigger": "pull_request.closed",
      "condition": "merged == true",
      "action": "set_field Status=Done and close issue"
    },
    {
      "name": "blocked label → Status Blocked",
      "trigger": "issues.labeled",
      "condition": "label == blocked",
      "action": "set_field Status=Blocked and assign @asurdev"
    },
    {
      "name": "Stale (7d no update) → notify",
      "trigger": "schedule.weekly",
      "action": "comment 'Stale issue (7+ days no update)' and label stale"
    },
    {
      "name": "Milestone 100% → notify",
      "trigger": "milestone.closed",
      "action": "comment '🎉 Milestone complete!' and notify @asurdev"
    }
  ]
}
