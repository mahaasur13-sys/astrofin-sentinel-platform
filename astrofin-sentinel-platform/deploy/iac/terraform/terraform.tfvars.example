# ============================================================
# home-cluster-iac — Terraform Variables (example)
# ============================================================
# Copy to terraform.tfvars and fill in real values
# DO NOT commit terraform.tfvars to git
# ============================================================

# ── Network ─────────────────────────────────────────────────
mesh_vpn_subnet  = "10.200.0.0/16"
wireguard_port  = 51820

vlan_segments = {
  mgmt    = { id = 10, subnet = "10.10.10.0/24", desc = "Management VLAN" }
  compute = { id = 20, subnet = "10.20.20.0/24", desc = "Compute/Cluster VLAN" }
  storage = { id = 30, subnet = "10.30.30.0/24", desc = "Ceph/storage VLAN" }
  edge    = { id = 40, subnet = "10.40.40.0/24", desc = "Edge devices VLAN" }
}

# ── MikroTik ────────────────────────────────────────────────
mikrotik_host     = "10.10.10.1"
mikrotik_user     = "admin"
mikrotik_password = "YOUR_MIKROTIK_PASSWORD"  # use TF_VAR env var instead

# ── Node IPs ─────────────────────────────────────────────────
home_node_ip  = "10.20.20.10"
edge_node_ip  = "10.20.20.11"
home_endpoint = ""   # leave empty for :0 (auto)
edge_endpoint = ""  # leave empty for :0 (auto)

# ── WireGuard keys (generate with: wg genkey) ────────────────
home_wg_pubkey  = "YOUR_HOME_PUBLIC_KEY"
edge_wg_pubkey = "YOUR_EDGE_PUBLIC_KEY"

# ── Ceph ─────────────────────────────────────────────────────
ceph_subnet               = "10.30.30.0/24"
ceph_osd_devices = {
  "home-rtx3060" = ["/dev/sdb"]
  "edge-rk3576"  = ["/dev/sdb"]
}
ceph_replication_factor = 2

# ── Slurm ────────────────────────────────────────────────────
slurm_cluster_name = "home-cluster"
slurm_control_host = "10.20.20.10"

# ── Ray ────────────────────────────────────────────────────────
ray_head_port = 6379

# ── MinIO S3 Backend ───────────────────────────────────────────────────────
# State is stored in MinIO (tf-state bucket), not on local disk.
# Set via environment variables (recommended):
#   export TF_VAR_minio_access_key="your-access-key"
#   export TF_VAR_minio_secret_key="your-secret-key"
# or uncomment and fill below (DO NOT commit real values to git):
# minio_access_key = "minioadmin"
# minio_secret_key = "minioadmin"