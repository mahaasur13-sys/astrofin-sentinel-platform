{
  "dashboard": {
    "title": "AstroFin Sentinel V5 – Infrastructure",
    "panels": [
      {
        "title": "Broker Errors",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(astrofin_broker_errors_total[5m])",
            "legendFormat": "errors/s"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "Ollama Health",
        "type": "stat",
        "targets": [
          {
            "expr": "astrofin_ollama_available",
            "legendFormat": "1=up, 0=down"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "Cache Hit Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(astrofin_cache_hits_total[5m]) / (rate(astrofin_cache_hits_total[5m]) + rate(astrofin_cache_misses_total[5m]))",
            "legendFormat": "hit rate"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "title": "Backtest Runs",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(astrofin_backtest_real_runs_total[5m])",
            "legendFormat": "real"
          },
          {
            "expr": "rate(astrofin_backtest_synthetic_runs_total[5m])",
            "legendFormat": "synthetic"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ],
    "refresh": "30s",
    "schemaVersion": 16
  }
}
