{
  "title": "AstroFin Agent Performance",
  "panels": [
    {
      "title": "OOS Fail Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "astrofin_oos_fail_rate"
        }
      ]
    },
    {
      "title": "Win Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "astrofin_meta_rl_win_rate"
        }
      ]
    },
    {
      "title": "Drawdown",
      "type": "timeseries",
      "targets": [
        {
          "expr": "astrofin_drawdown_percent"
        }
      ]
    }
  ]
}
