{
  "annotations": {
    "list": []
  },
  "description": "RAG retrieval observability dashboard (P2-04). Tracks query throughput, latency, error rate, BM25 index freshness, and chunk-count distribution across backends (pgvector, faiss) and domains.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Total RAG queries per second, split by backend. Stacked area shows pgvector vs faiss share of traffic.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {"mode": "normal", "group": "A"}
          },
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "title": "RAG Throughput (queries/s by backend)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (backend) (rate(astrofin_rag_queries_total[5m]))",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Error rate: failed RAG queries / total RAG queries. Watch for spikes — should stay near 0 except during backend outages.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "title": "RAG Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(astrofin_rag_queries_total{status=\"error\"}[5m])) / sum(rate(astrofin_rag_queries_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "End-to-end RAG query latency percentiles (seconds). p50 is typical, p95 is the SLA-relevant number.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "title": "RAG Latency (p50, p95, p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(astrofin_rag_latency_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(astrofin_rag_latency_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(astrofin_rag_latency_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Count of RAG errors by failure stage and exception kind. Useful to spot e.g. embedding-timeouts vs SQL connection drops.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          }
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "title": "RAG Errors (by stage × kind)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (stage, kind) (rate(astrofin_rag_errors_total[5m]))",
          "legendFormat": "{{stage}} / {{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Unix epoch (seconds) of the last BM25 index build. If the value is 0, the index has never been built; if it stops advancing, refresh() is broken.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 1000000}
            ]
          },
          "unit": "dateTimeAsIso"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 16},
      "id": 5,
      "title": "BM25 Index Last Refresh",
      "type": "stat",
      "targets": [
        {
          "expr": "astrofin_rag_bm25_refresh_timestamp",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Time since the BM25 index was last built, in seconds. Stale index means new documents ingested via RAGClient.store() won't be findable lexically.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 300},
              {"color": "red", "value": 900}
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 16},
      "id": 6,
      "title": "BM25 Index Age",
      "type": "stat",
      "targets": [
        {
          "expr": "time() - astrofin_rag_bm25_refresh_timestamp",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Distribution of chunks returned per query (post-filter). If most queries return 0 chunks, check embedding relevance or min_score threshold.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 16},
      "id": 7,
      "title": "Chunks Returned (p50, p95)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(astrofin_rag_chunks_returned_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(astrofin_rag_chunks_returned_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Average relevance score of the most recent RAG query, per backend. Sudden drops can signal corpus drift or embedding model changes.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "min": 0,
          "max": 1,
          "unit": "none"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
      "id": 8,
      "title": "Avg Relevance Score (last query)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "astrofin_rag_relevance_avg",
          "legendFormat": "avg",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "description": "Total RAG errors by stage over the selected time range. Use to triage where failures are concentrated.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          }
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
      "id": 9,
      "title": "RAG Errors by Stage (total)",
      "type": "bargauge",
      "targets": [
        {
          "expr": "sum by (stage) (increase(astrofin_rag_errors_total[$__range]))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["astrofin", "rag", "p2-04"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "AstroFin RAG Observability (P2-04)",
  "uid": "astrofin-rag-p2-04",
  "version": 1,
  "weekStart": ""
}
