global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: '{{ cluster_name }}'

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'nodes'
    static_configs:
      - targets: ['10.20.20.10:9100', '10.20.20.20:9100', '10.40.40.30:9100']
        labels:
          role: compute

  - job_name: 'slurm'
    static_configs:
      - targets: ['10.20.20.10:6817']
        labels:
          service: slurmctld

  - job_name: 'ceph'
    static_configs:
      - targets: ['10.30.30.10:9283']
        labels:
          service: ceph-mgr

  - job_name: 'gpu'
    static_configs:
      - targets: ['10.20.20.10:9400']
        labels:
          node: rtx-node
