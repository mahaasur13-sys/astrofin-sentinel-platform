[flake8]
max-line-length = 120
max-complexity = 10
exclude =
    .venv,
    venv,
    __pycache__,
    .git,
    .pytest_cache,
    .mypy_cache,
    .ruff_cache,
    .hypothesis,
    dist,
    build,
    *.egg-info,
    node_modules,
    web/assets,
    data,
extend-ignore =
    E203,
    E266,
    E501,
    W503,
    F401,
    F403
per-file-ignores =
    tests/*:S101