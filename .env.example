# =============================================================================
# AstroFin Sentinel Platform — environment variables for docker-compose
# Copy to .env (docker-compose picks it up automatically)
# =============================================================================

# --- Postgres / TimescaleDB ---------------------------------------------
POSTGRES_USER=astrofin
POSTGRES_PASSWORD=astrofin
POSTGRES_DB=astrofin
POSTGRES_PORT=5432

# --- Redis ---------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Web dashboard -------------------------------------------------------
WEB_PORT=8050
GUNICORN_WORKERS=4

# --- ML Inference API ----------------------------------------------------
ML_PORT=8081
ML_MODEL_PATH=/app/models/failure_xgb_v2.pkl
ML_FEATURES_PATH=/app/models/features.txt
ML_LOG_LEVEL=INFO

# --- Feature Pipeline ----------------------------------------------------
FEATURE_PIPELINE_PORT=8090
FEATURE_PIPELINE_INTERVAL_SEC=60

# --- GPU Worker ----------------------------------------------------------
ENABLE_GPU_WORKER=false
GPU_WORKER_PORT=8000
CUDA_VISIBLE_DEVICES=0
WORKER_ID=gpu-worker-01

# --- Prometheus ----------------------------------------------------------
PROMETHEUS_PORT=9090

# --- Misc ----------------------------------------------------------------
LOG_LEVEL=INFO
TZ=UTC