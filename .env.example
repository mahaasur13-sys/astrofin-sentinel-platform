# =============================================================================
# AstroFin Sentinel Platform — canonical environment variables
# Source of truth: core/settings.py (pydantic-settings, 90 fields)
#
# ⚠️  This file is checked into git with PLACEHOLDER values only.
#     Real secrets are loaded from .env (gitignored) or from a SOPS-encrypted
#     file referenced by the SOPS env vars at the bottom of this file.
#     Never replace a placeholder with a real value here.
#
# Conventions:
#   *_KEY / *_SECRET / *_PASSWORD / *_TOKEN / DSN  →  SecretStr (masked in logs)
#   everything else                                →  plain string
# =============================================================================

# ─── Environment discriminator ──────────────────────────────────────────────
# Allowed values: development | test | production | staging
ENV=development

# ─── Required secrets (SecretStr) ───────────────────────────────────────────
# Static API key sent in X-API-Key header for service-to-service auth.
API_KEY=your_api_key_here
# Redis connection URL. Use rediss:// in production with AUTH.
REDIS_URL=redis://localhost:6379/0
# PostgreSQL connection URL (sqlalchemy-compatible).
DATABASE_URL=postgresql://astrofin:astrofin@localhost:5432/astrofin
# Filesystem paths to RS256 JWT signing keys (PEM).
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem

# ─── CCXT / exchange credentials (optional) ────────────────────────────────
CCXT_API_KEY=your_ccxt_api_key_here
CCXT_API_SECRET=your_ccxt_api_secret_here
CCXT_EXCHANGE=binance
CCXT_SANDBOX_MODE=true
CCXT_RATE_LIMIT_MS=50
CCXT_LIVE_MODE=false
CCXT_RECONNECT_ATTEMPTS=3
CCXT_RECONNECT_DELAY_S=2.0
CCXT_ENABLE_RATE_LIMIT=true
LIVE_DATA_ENABLED=true

# ─── Auth toggles ──────────────────────────────────────────────────────────
REQUIRE_AUTH=true

# ─── Web / dashboard ───────────────────────────────────────────────────────
WEB_PORT=8050
GUNICORN_WORKERS=4
ENABLE_INTERNAL_ENDPOINTS=false
CORS_ORIGINS=["*"]
# Flask/Dash session signing key — must be a long random string in production.
SECRET_KEY=your_dash_secret_key_here
ALLOWED_ORIGINS=*
DEBUG_MODE=false
PORT=8050
URL_BASE_PATHNAME=/

# ─── ML inference API ──────────────────────────────────────────────────────
ML_PORT=8081
ML_MODEL_PATH=/app/models/failure_xgb_v2.pkl
ML_FEATURES_PATH=/app/models/features.txt

# ─── Feature pipeline ──────────────────────────────────────────────────────
FEATURE_PIPELINE_PORT=8090
FEATURE_PIPELINE_INTERVAL_SEC=60

# ─── GPU worker ────────────────────────────────────────────────────────────
ENABLE_GPU_WORKER=false
GPU_WORKER_PORT=8000
CUDA_VISIBLE_DEVICES=0
WORKER_ID=gpu-worker-01

# ─── Observability ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090
# Sentry DSN — leave blank to disable error reporting.
SENTRY_DSN=
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password_here

# ─── Render / service identity ─────────────────────────────────────────────
RENDER_MODE=production
SERVICE_NAME=astrofin-sentinel
JAEGER_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ─── Postgres / Redis connection (in addition to URL) ──────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=astrofin
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=astrofin
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── RAG / Knowledge ──────────────────────────────────────────────────────
RAG_BACKEND=pgvector
# Connection string for the knowledge/pgvector DB.
AFS_PG_DSN=postgresql://astrofin:astrofin@localhost:5432/astrofin_kb
RAG_LEGACY_FALLBACK=true
RAG_FAISS_DIR=knowledge/indexes

# ─── Meta-RL feature flags ─────────────────────────────────────────────────
META_RL_MODE=historical
META_RL_SYMBOL=BTC/USDT
META_RL_TIMEFRAME=1h
META_RL_ENABLED=true
RISK_INTEGRATION_ENABLED=true
KARL_META_UPDATE_ENABLED=true
EXECUTION_SANITY_ENABLED=true
ALPHA_DECAY_DETECTION=true
ALPHA_DECAY_REWARD_DROP_PCT=0.30
ALPHA_DECAY_WINDOW_GENS=5
DECAY_KILL_THRESHOLD=0.15
DIVERSITY_ENFORCEMENT=true
MIN_DIVERSITY_POPULATION=3
DIVERSITY_SIMILARITY_THRESHOLD=0.85
BATCH_EVALUATION_SIZE=64
WALK_FORWARD_ENABLED=true
OOS_OVERFIT_THRESHOLD=0.20
OOS_SHARPE_DEGRADATION_LIMIT=0.50
HYPEROPT_ENABLED=false

# ─── Meta-RL composite ranking weights ─────────────────────────────────────
CW_SHARPE=0.35
CW_WIN_RATE=0.20
CW_PNL=0.25
CW_STABILITY=0.20
COMPOSITE_RANKING_ENABLED=true

# ─── Meta-RL reports / alerts ──────────────────────────────────────────────
HTML_REPORTS_ENABLED=true
REPORTS_OUTPUT_DIR=data/reports
REPORTS_BASE_URL=/reports
TELEGRAM_ALERTS_ENABLED=false
# Bot token issued by @BotFather. Treat as a secret.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_REWARD_ALERT=0.0

# ─── Pressure field (coordination) ─────────────────────────────────────────
PRESSURE_FIELD_ENABLED=false
PRESSURE_FIELD_K_NEIGHBORS=3
PRESSURE_FIELD_INFLUENCE_STRENGTH=0.15
PRESSURE_FIELD_MIN_CONSENSUS=0.5

# ─── Misc ──────────────────────────────────────────────────────────────────
TZ=UTC

# ─── SOPS / secrets backend (optional) ─────────────────────────────────────
# When SOPS_FILE is set, core.settings loads secrets from the decrypted file
# instead of the .env file. See docs/secret_scan.md for the rotation runbook.
# SOPS_FILE=.secrets.prod.enc.yaml
# SOPS_AGE_KEY_FILE=/run/secrets/age.key
