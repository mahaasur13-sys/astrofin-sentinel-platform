# AstroFin Sentinel V5 — Environment Template
# Copy to .env and fill in your values

# Authentication
API_KEY=change-me-to-a-secure-random-string
REQUIRE_AUTH=true

# Database
DB_BACKEND=postgresql
POSTGRES_HOST=localhost
POSTGRES_USER=astrofin
POSTGRES_PASSWORD=astrofin
POSTGRES_DB=astrofin

# Redis
REDIS_URL=redis://localhost:6379

# Market Data
MARKET_DATA_SOURCE=synthetic
BINANCE_API_BASE=https://api.binance.com
COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# Monitoring
METRICS_AUTH_ENABLED=false
METRICS_API_KEY=

# Export
GIT_EXPORT_ENABLED=true
EXPORT_ON_EVOLUTION=true
