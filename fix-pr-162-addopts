#!/bin/bash
# Восстановление --ignore в addopts pyproject.toml для PR #162
# Запускать на Pop!_OS в ~/astrofin-sentinel-platform (на ветке ci/remove-coderabbit-safety-scan)

set -e
cd ~/astrofin-sentinel-platform

# Уже на ветке ci/remove-coderabbit-safety-scan?

# 1. Смотрим текущий addopts
echo "=== Текущий addopts ==="
grep -n "addopts" pyproject.toml

# 2. Сохраняем бэкап
cp pyproject.toml pyproject.toml.bak.$(date +%s)

# 3. Патчим: добавляем --ignore для kepler/validator/core_aspects
# Идем по строке с addopts и дописываем --ignore=tests/test_kepler_differential.py \
#   --ignore=tests/test_kepler_property.py --ignore=tests/test_validator.py
# ТОЛЬКО если их там ещё нет
python3 - <<'PY'
from pathlib import Path
p = Path("pyproject.toml")
text = p.read_text(encoding="utf-8")

ignores = [
    "tests/test_kepler_differential.py",
    "tests/test_kepler_property.py",
    "tests/test_validator.py",
    "tests/test_core_aspects.py",
]

# Найдём строку addopts = "..." (она одна)
import re
m = re.search(r'(addopts\s*=\s*")([^"]*)(")', text)
if not m:
    raise SystemExit("addopts not found")

prefix, val, suffix = m.group(1), m.group(2), m.group(3)
for path in ignores:
    flag = f"--ignore={path}"
    if flag not in val:
        val = val.rstrip() + " " + flag
        print(f"+ добавлен {flag}")
    else:
        print(f"= {flag} уже есть")

new = text[:m.start()] + prefix + val + suffix + text[m.end():]
p.write_text(new, encoding="utf-8")
print("✔ pyproject.toml обновлён")
PY

echo
echo "=== Проверка ==="
grep -n "addopts" pyproject.toml

echo
echo "=== Commit + push ==="
git add pyproject.toml
git commit -m "fix(ci): restore --ignore flags for kepler/validator/core_aspects tests (KI-125a)"
git push --force-with-lease

echo
echo "=== Готово. Ждём CI: ==="
gh pr checks 162 --watch --interval 15 --fail-fast
